{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "outDir": "dist",
    "sourceMap": true,
    "types": ["office-js"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
