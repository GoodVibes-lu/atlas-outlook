<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
           xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
           xsi:type="MailApp">

  <Id>7f5e9b1b-a743-4ba9-aee6-3743356ca12c</Id>
  <Version>1.0.0</Version>
  <ProviderName>GOOD VIBES</ProviderName>
  <DefaultLocale>fr-FR</DefaultLocale>
  <DisplayName DefaultValue="ATLAS" />
  <Description DefaultValue="Liaison emails ↔ projets ATLAS — GOOD VIBES" />
  <IconUrl DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/assets/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/assets/icon-128.png" />
  <SupportUrl DefaultValue="https://vibes.lu" />

  <AppDomains>
    <AppDomain>https://api.airtable.com</AppDomain>
    <AppDomain>https://content.airtable.com</AppDomain>
    <AppDomain>https://api.anthropic.com</AppDomain>
    <AppDomain>https://graph.microsoft.com</AppDomain>
    <AppDomain>https://login.microsoftonline.com</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/index.html?mode=read" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="ReadOrEdit" />
  </Rule>

  <DisableEntityHighlighting>true</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.5">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>

            <!-- ── FunctionFile : page invisible qui charge commands.js pour exécuter
                 les ExecuteFunction (Traité / Reporter / Archiver) sans ouvrir de pane. ── -->
            <FunctionFile resid="commandsFileUrl" />

            <!-- ── Reading an email: Toolbar buttons (always visible in ribbon) ── -->
            <!-- 4 boutons : ouvrir pane + Traité + Reporter + Archiver. Les 3 derniers
                 sont des FunctionCommand qui s'exécutent SANS ouvrir de pane — actions
                 immédiates sur le mail courant. Compense l'absence de pin sur Mac. -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="atlasReadGroup">
                  <Label resid="groupLabel" />

                  <Control xsi:type="Button" id="openAtlasRead">
                    <Label resid="readBtnLabel" />
                    <Supertip>
                      <Title resid="readBtnTitle" />
                      <Description resid="readBtnDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="taskpaneReadUrl" />
                      <SupportsPinning>true</SupportsPinning>
                    </Action>
                  </Control>

                  <!-- ✓ Traité : exécute markTagDone + catégorie verte. Pas de pane. -->
                  <Control xsi:type="Button" id="atlasDoneBtn">
                    <Label resid="doneBtnLabel" />
                    <Supertip>
                      <Title resid="doneBtnLabel" />
                      <Description resid="doneBtnDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>atlasDoneCommand</FunctionName>
                    </Action>
                  </Control>

                  <!-- ⏰ Reporter : snooze à demain 8h + catégorie bleue. Pas de pane. -->
                  <Control xsi:type="Button" id="atlasSnoozeBtn">
                    <Label resid="snoozeBtnLabel" />
                    <Supertip>
                      <Title resid="snoozeBtnLabel" />
                      <Description resid="snoozeBtnDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>atlasSnoozeCommand</FunctionName>
                    </Action>
                  </Control>

                  <!-- 📦 Archiver : archive + déplace dans dossier habituel. Pas de pane. -->
                  <Control xsi:type="Button" id="atlasArchiveBtn">
                    <Label resid="archiveBtnLabel" />
                    <Supertip>
                      <Title resid="archiveBtnLabel" />
                      <Description resid="archiveBtnDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>atlasArchiveCommand</FunctionName>
                    </Action>
                  </Control>

                  <!-- 🔄 Re-analyser : force une analyse Claude. Pas de pane. -->
                  <Control xsi:type="Button" id="atlasReanalyzeBtn">
                    <Label resid="reanalyzeBtnLabel" />
                    <Supertip>
                      <Title resid="reanalyzeBtnLabel" />
                      <Description resid="reanalyzeBtnDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>atlasReanalyzeCommand</FunctionName>
                    </Action>
                  </Control>

                </Group>

                <!-- 2e groupe : Projets — ouvre le pane sur le tab voulu -->
                <Group id="atlasProjetGroup">
                  <Label resid="projetGroupLabel" />

                  <Control xsi:type="Button" id="atlasLinkBtn">
                    <Label resid="ctxLinkLabel" />
                    <Supertip>
                      <Title resid="ctxLinkLabel" />
                      <Description resid="ctxLinkDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="ctxLinkUrl" />
                      <SupportsPinning>true</SupportsPinning>
                    </Action>
                  </Control>

                  <Control xsi:type="Button" id="atlasInfoBtn">
                    <Label resid="ctxInfoLabel" />
                    <Supertip>
                      <Title resid="ctxInfoLabel" />
                      <Description resid="ctxInfoDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="ctxInfoUrl" />
                      <SupportsPinning>true</SupportsPinning>
                    </Action>
                  </Control>

                  <Control xsi:type="Button" id="atlasCreateBtn">
                    <Label resid="ctxCreateLabel" />
                    <Supertip>
                      <Title resid="ctxCreateLabel" />
                      <Description resid="ctxCreateDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="ctxCreateUrl" />
                      <SupportsPinning>true</SupportsPinning>
                    </Action>
                  </Control>

                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- ── Composing an email: Toolbar button ── -->
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="atlasComposeGroup">
                  <Label resid="groupLabel" />
                  <Control xsi:type="Button" id="openAtlasCompose">
                    <Label resid="composeBtnLabel" />
                    <Supertip>
                      <Title resid="composeBtnTitle" />
                      <Description resid="composeBtnDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="taskpaneComposeUrl" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- ── Context menu on message (right-click) ── -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="atlasContextGroup">
                  <Label resid="groupLabel" />

                  <Control xsi:type="Menu" id="atlasContextMenu">
                    <Label resid="ctxMenuLabel" />
                    <Supertip>
                      <Title resid="ctxMenuTitle" />
                      <Description resid="ctxMenuDesc" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="icon16" />
                      <bt:Image size="32" resid="icon32" />
                      <bt:Image size="80" resid="icon80" />
                    </Icon>
                    <Items>
                      <Item id="ctxLinkProjet">
                        <Label resid="ctxLinkLabel" />
                        <Supertip>
                          <Title resid="ctxLinkLabel" />
                          <Description resid="ctxLinkDesc" />
                        </Supertip>
                        <Icon>
                          <bt:Image size="16" resid="icon16" />
                          <bt:Image size="32" resid="icon32" />
                          <bt:Image size="80" resid="icon80" />
                        </Icon>
                        <Action xsi:type="ShowTaskpane">
                          <SourceLocation resid="ctxLinkUrl" />
                        </Action>
                      </Item>
                      <Item id="ctxVoirProjet">
                        <Label resid="ctxInfoLabel" />
                        <Supertip>
                          <Title resid="ctxInfoLabel" />
                          <Description resid="ctxInfoDesc" />
                        </Supertip>
                        <Icon>
                          <bt:Image size="16" resid="icon16" />
                          <bt:Image size="32" resid="icon32" />
                          <bt:Image size="80" resid="icon80" />
                        </Icon>
                        <Action xsi:type="ShowTaskpane">
                          <SourceLocation resid="ctxInfoUrl" />
                        </Action>
                      </Item>
                      <Item id="ctxCreerProjet">
                        <Label resid="ctxCreateLabel" />
                        <Supertip>
                          <Title resid="ctxCreateLabel" />
                          <Description resid="ctxCreateDesc" />
                        </Supertip>
                        <Icon>
                          <bt:Image size="16" resid="icon16" />
                          <bt:Image size="32" resid="icon32" />
                          <bt:Image size="80" resid="icon80" />
                        </Icon>
                        <Action xsi:type="ShowTaskpane">
                          <SourceLocation resid="ctxCreateUrl" />
                        </Action>
                      </Item>
                    </Items>
                  </Control>

                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="icon16" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/assets/icon-16.png" />
          <bt:Image id="icon32" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/assets/icon-32.png" />
          <bt:Image id="icon80" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/assets/icon-80.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="taskpaneReadUrl" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/index.html?mode=read" />
          <bt:Url id="taskpaneComposeUrl" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/index.html?mode=compose" />
          <bt:Url id="ctxLinkUrl" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/index.html?mode=read&amp;tab=link" />
          <bt:Url id="ctxInfoUrl" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/index.html?mode=read&amp;tab=info" />
          <bt:Url id="ctxCreateUrl" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/index.html?mode=read&amp;tab=create" />
          <bt:Url id="commandsFileUrl" DefaultValue="https://goodvibes-lu.github.io/atlas-outlook/commands.html" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="groupLabel" DefaultValue="ATLAS" />
          <bt:String id="readBtnLabel" DefaultValue="ATLAS" />
          <bt:String id="readBtnTitle" DefaultValue="Ouvrir ATLAS" />
          <bt:String id="composeBtnLabel" DefaultValue="Templates" />
          <bt:String id="composeBtnTitle" DefaultValue="Templates ATLAS" />
          <bt:String id="ctxMenuLabel" DefaultValue="ATLAS" />
          <bt:String id="ctxMenuTitle" DefaultValue="Actions ATLAS" />
          <bt:String id="ctxLinkLabel" DefaultValue="Lier a un projet ATLAS" />
          <bt:String id="ctxInfoLabel" DefaultValue="Voir le projet" />
          <bt:String id="ctxCreateLabel" DefaultValue="Creer un projet" />
          <bt:String id="doneBtnLabel" DefaultValue="Traite" />
          <bt:String id="snoozeBtnLabel" DefaultValue="Reporter" />
          <bt:String id="archiveBtnLabel" DefaultValue="Archiver" />
          <bt:String id="reanalyzeBtnLabel" DefaultValue="Re-analyser" />
          <bt:String id="projetGroupLabel" DefaultValue="Projet" />
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="readBtnDesc" DefaultValue="Lier cet email à un projet, voir les infos ou créer un nouveau projet ATLAS" />
          <bt:String id="composeBtnDesc" DefaultValue="Insérer un template email avec adaptation de tonalité automatique (ARGO)" />
          <bt:String id="ctxMenuDesc" DefaultValue="Lier, consulter ou créer un projet ATLAS depuis le menu contextuel" />
          <bt:String id="ctxLinkDesc" DefaultValue="Lier cet email à un projet existant dans ATLAS" />
          <bt:String id="ctxInfoDesc" DefaultValue="Afficher les informations du projet lié à cet email" />
          <bt:String id="ctxCreateDesc" DefaultValue="Créer un nouveau projet ATLAS à partir de cet email" />
          <bt:String id="doneBtnDesc" DefaultValue="Marquer ce mail comme traité (tag vert ATLAS apparait dans l'inbox)" />
          <bt:String id="snoozeBtnDesc" DefaultValue="Reporter ce mail à demain 8h (tag bleu ATLAS apparait dans l'inbox)" />
          <bt:String id="archiveBtnDesc" DefaultValue="Archiver et ranger automatiquement ce mail dans son dossier habituel" />
          <bt:String id="reanalyzeBtnDesc" DefaultValue="Forcer une nouvelle analyse Claude (corrige une mauvaise classification)" />
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
